    # Search for integer solutions to the magic square of squares equation
# y^2 = 2*n^2*(m^2 - n^2)^2*k^4 + [2*(m*n)^2 - 4*m*n*(m^2 - n^2)]*k^2 + [m^2 + k^2*(m^2 - n^2)^2]/2

def search_solutions(m_max, n_max, k_max):
    """
    Search for integer solutions (m, n, k, y) where:
    - 1 <= n < m <= m_max
    - 1 <= k <= k_max
    """
    solutions = []
    
    for m in range(1, m_max + 1):
        for n in range(1, m):  # n < m since R_3 < R_2
            if gcd(m, n) != 1:  # Optional: search for coprime pairs first
                continue
                
            # Precompute common terms for efficiency
            m2 = m^2
            n2 = n^2
            m2_minus_n2 = m2 - n2
            m2_minus_n2_sq = m2_minus_n2^2
            mn = m * n
            mn2 = (m * n)^2
            
            for k in range(1, k_max + 1):
                k2 = k^2
                k4 = k^4
                
                # Compute the right-hand side
                term1 = 2 * n2 * m2_minus_n2_sq * k4
                term2 = (2 * mn2 - 4 * mn * m2_minus_n2) * k2
                term3 = (m2 + k2 * m2_minus_n2_sq) / 2
                
                rhs = term1 + term2 + term3
                
                # Check if rhs is a perfect square
                if rhs.is_integer():
                    rhs_int = Integer(rhs)
                    if rhs_int >= 0 and rhs_int.is_square():
                        y = rhs_int.sqrt()
                        if y.is_integer():
                            y_int = Integer(y)
                            solutions.append((m, n, k, y_int))
                            print(f"Solution found: m={m}, n={n}, k={k}, y={y_int}")
                            print(f"  Verification: {y_int}^2 = {rhs_int}")
                            print(f"  Terms: {term1} + {term2} + {term3} = {rhs_int}")
                            print()
    
    return solutions

