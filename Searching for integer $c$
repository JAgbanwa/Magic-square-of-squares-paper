# More efficient version that checks if the expression can be a square before full computation
def efficient_search(m_max, n_max, k_max):
    """More efficient search with early termination checks"""
    solutions = []
    
    for m in range(1, m_max + 1):
        for n in range(1, m):
            # Check if the expression can potentially be a square modulo some number
            m2 = m^2
            n2 = n^2
            m2_minus_n2 = m2 - n2
            
            if m2_minus_n2 == 0:  # m = n, not allowed
                continue
                
            for k in range(1, k_max + 1):
                # Compute the value
                value = (2 * n2 * (m2_minus_n2)^2 * k^4 + 
                        (2 * (m*n)^2 - 4 * m * n * m2_minus_n2) * k^2 + 
                        (m2 + k^2 * (m2_minus_n2)^2) / 2)
                
                if value in ZZ and value >= 0:
                    if is_square(value):
                        y = sqrt(value)
                        if y in ZZ:
                            solutions.append((m, n, k, y))
                            print(f"SOLUTION: m={m}, n={n}, k={k}, y={y}")
                            print(f"  Value = {value}")
                            
                            # This would correspond to c^2 in your magic square
                            c_squared = value
                            print(f"  This gives c^2 = {c_squared}")
                            if is_square(c_squared):
                                c = sqrt(c_squared)
                                print(f"  => c = {c} (perfect square!)\n")
                            else:
                                print(f"  => c = sqrt({c_squared}) (not a perfect square)\n")
    
    return solutions

